<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- Dogfood: consume the current Fallout -preview packages, not a stale nuget.org release. -->
    <add key="github" value="https://nuget.pkg.github.com/Fallout-build/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceCredentials>
    <github>
      <add key="Username" value="fallout-build" />
      <add key="ClearTextPassword" value="%FALLOUT_PACKAGES_TOKEN%" />
    </github>
  </packageSourceCredentials>
  <packageSourceMapping>
    <clear />
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github">
      <package pattern="Fallout.*" />
      <package pattern="Nuke.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
